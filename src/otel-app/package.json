{
  "name": "otel-demo-app",
  "version": "1.0.0",
  "description": "A simple Node.js app with OpenTelemetry instrumentation",
  "main": "index.js",
  "scripts": {
    "start": "node -r ./tracing.js index.js"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/api-logs": "^0.220.0",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.220.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.220.0",
    "@opentelemetry/exporter-logs-otlp-http": "^0.220.0",
    "@opentelemetry/resources": "^2.9.0",
    "@opentelemetry/sdk-node": "^0.220.0",
    "@opentelemetry/sdk-metrics": "^2.9.0",
    "@opentelemetry/sdk-logs": "^0.220.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "@pyroscope/nodejs": "^0.4.13",
    "express": "^4.22.2"
  },
  "comment": "p-limit is pinned to 3.x (the last CommonJS release) via overrides: @pyroscope/nodejs is CJS and require()s p-limit, but p-limit >=4 is ESM-only, which breaks under require() on some Node versions (ERR_REQUIRE_ESM).",
  "overrides": {
    "p-limit": "3.1.0"
  }
}
